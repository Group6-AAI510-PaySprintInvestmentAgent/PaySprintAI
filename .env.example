# =============================================================================
# PaySprint Investment Agent - Environment Variables

# --- Gemini ---------------
GEMINI_API_KEY=your-gemini-key-here

# Models routed through Gemini's OpenAI-compatible endpoint.
# flash-lite has the most generous free-tier rate limits (best for the
# multi-call ReAct loop and the 3x consistency test).
MODEL_REASONING=gemini-2.5-flash
MODEL_SUMMARY=gemini-2.5-flash-lite

# --- OpenAI (optional) ----------------------------------------------
# Only needed if you switch back to OpenAI. Leave blank when using Gemini.
OPENAI_API_KEY=

# --- Offline demo mode (optional) --------------------------------------------
# Set to 1 to run with the built-in fake LLM (no key, no real tool calls).
# Leave as 0 for real runs.
USE_FAKE_LLM=0
